---
import { optimizeRemoteImageSrc } from '../lib/images';

interface Props {
	src: string;
	alt: string;
	width: number;
	height: number;
	loading?: 'lazy' | 'eager';
	fetchpriority?: 'high' | 'low' | 'auto';
	id?: string;
	class?: string;
}

const {
	src,
	alt,
	width,
	height,
	loading = 'lazy',
	fetchpriority,
	id,
	class: className,
} = Astro.props;
---

<img
	src={optimizeRemoteImageSrc(src, width, height)}
	alt={alt}
	width={width}
	height={height}
	loading={loading}
	decoding="async"
	fetchpriority={fetchpriority}
	id={id}
	class={className}
/>
