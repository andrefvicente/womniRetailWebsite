---
import { Image } from 'astro:assets';
import type { Product } from '../data/types';
import { formatPrice, useTranslations } from '../i18n';
import { sizeLabels } from '../data/products';

interface Props {
	product: Product;
}

const t = useTranslations(Astro.currentLocale);
const { product } = Astro.props;
const discount =
	product.originalPrice && product.originalPrice > product.price
		? Math.round((1 - product.price / product.originalPrice) * 100)
		: null;
const minSize = product.sizes[0] ? sizeLabels[product.sizes[0]] : '';
---

<article class="product-card" data-product-card data-slug={product.slug}>
	<a href={`/product/${product.slug}`} class="product-card__media">
		<Image src={product.image} alt={product.name} width={400} height={500} loading="lazy" />
		{product.badge === 'sale' && discount && <span class="badge badge--sale">-{discount}%</span>}
		{product.badge === 'new' && <span class="badge badge--new">{t.badges.new}</span>}
		{product.badge === 'bestseller' && <span class="badge badge--new">{t.badges.bestseller}</span>}
	</a>
	<div class="product-card__body">
		<div class="product-card__meta">
			<span class="stars" aria-label={t.aria.stars(product.rating)}>
				{'★'.repeat(Math.floor(product.rating))}{product.rating % 1 >= 0.5 ? '½' : ''}
			</span>
			<span class="product-card__reviews">({product.reviewCount})</span>
		</div>
		<h3 class="product-card__title">
			<a href={`/product/${product.slug}`}>{product.name}</a>
		</h3>
		<p class="product-card__attrs">
			{t.materials[product.material]} · {t.styles[product.style]}
		</p>
		<div class="product-card__price">
			<span class="product-card__current">{formatPrice(product.price, Astro.currentLocale)}</span>
			{product.originalPrice && (
				<span class="product-card__was">{formatPrice(product.originalPrice, Astro.currentLocale)}</span>
			)}
		</div>
		{minSize && (
			<p class="product-card__sizes">
				{t.product.fromSize} {minSize}
			</p>
		)}
	</div>
</article>

<style>
	.product-card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
	}
	.product-card__media {
		position: relative;
		aspect-ratio: 4 / 5;
		overflow: hidden;
		background: #f0eeeb;
	}
	.product-card__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}
	.product-card:hover .product-card__media img {
		transform: scale(1.03);
	}
	.product-card__media .badge {
		position: absolute;
		top: 0.75rem;
		left: 0.75rem;
	}
	.product-card__body {
		padding: 1rem 0.25rem 1.25rem;
	}
	.product-card__meta {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.75rem;
	}
	.product-card__reviews {
		color: var(--color-muted);
	}
	.product-card__title {
		margin: 0.35rem 0 0;
		font-family: var(--font-display);
		font-size: 1.125rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.product-card__title a:hover {
		color: var(--color-accent);
	}
	.product-card__attrs {
		margin: 0.25rem 0 0;
		font-size: 0.8125rem;
		color: var(--color-muted);
	}
	.product-card__price {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}
	.product-card__current {
		font-weight: 600;
	}
	.product-card__was {
		font-size: 0.875rem;
		color: var(--color-muted);
		text-decoration: line-through;
	}
	.product-card__sizes {
		margin: 0.25rem 0 0;
		font-size: 0.75rem;
		color: var(--color-muted);
	}
</style>
