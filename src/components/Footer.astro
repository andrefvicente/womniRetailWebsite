---
import { brandLogo } from '../data/images';
import { footerLinks } from '../data/navigation';
import { loadSiteNavigation } from '../lib/site/navigation';
import Newsletter from './Newsletter.astro';
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
const { footerShop, defaultCatalogHref } = await loadSiteNavigation();
---

<footer class="footer">
	<div class="container">
		<Newsletter />
		<div class="footer__grid">
			<div class="footer__brand">
				<a href="/" class="footer__logo">
					<img src={brandLogo} alt={t.brand} width="200" height="44" decoding="async" />
				</a>
				<p>{t.footer.tagline}</p>
			</div>
			<div>
				<h3>{t.footer.shop}</h3>
				<ul>
					{footerShop.map((link) => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
					{defaultCatalogHref !== '/' && (
						<>
							<li><a href={`${defaultCatalogHref}?sort=new`}>{t.footer.links.newArrivals}</a></li>
							<li><a href={`${defaultCatalogHref}?sale=true`}>{t.footer.links.sale}</a></li>
						</>
					)}
				</ul>
			</div>
			<div>
				<h3>{t.footer.customerCare}</h3>
				<ul>
					{footerLinks.help.map((link) => (
						<li><a href={link.href}>{t.footer.links[link.key]}</a></li>
					))}
				</ul>
			</div>
			<div>
				<h3>{t.footer.about}</h3>
				<ul>
					{footerLinks.about.map((link) => (
						<li><a href={link.href}>{t.footer.links[link.key]}</a></li>
					))}
				</ul>
			</div>
		</div>
		<div class="footer__bottom">
			<p>&copy; {new Date().getFullYear()} {t.brand}. {t.footer.rights}</p>
			<div class="footer__payments">
				<span>Visa</span>
				<span>Mastercard</span>
				<span>PayPal</span>
				<span>Klarna</span>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		margin-top: 4rem;
		padding: 3rem 0 2rem;
		background: var(--color-ink);
		color: #d4d4d4;
	}
	.footer__grid {
		display: grid;
		grid-template-columns: 1.5fr repeat(3, 1fr);
		gap: 2rem;
		padding: 3rem 0 2rem;
		border-top: 1px solid #333;
	}
	.footer__logo {
		display: inline-block;
	}
	.footer__logo img {
		display: block;
		height: 2.5rem;
		width: auto;
	}
	.footer__brand p {
		margin-top: 0.75rem;
		font-size: 0.875rem;
		line-height: 1.6;
		max-width: 20rem;
	}
	.footer h3 {
		margin: 0 0 1rem;
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: white;
	}
	.footer ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.footer li + li {
		margin-top: 0.5rem;
	}
	.footer a {
		font-size: 0.875rem;
		transition: color var(--transition);
	}
	.footer a:hover {
		color: white;
	}
	.footer__bottom {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 2rem;
		border-top: 1px solid #333;
		font-size: 0.8125rem;
	}
	.footer__payments {
		display: flex;
		gap: 1rem;
		opacity: 0.7;
	}
	@media (max-width: 768px) {
		.footer__grid {
			grid-template-columns: 1fr 1fr;
		}
		.footer__brand {
			grid-column: 1 / -1;
		}
	}
</style>
