---
import { brandLogo } from '../data/images';
import NavMenu from './NavMenu.astro';
import { loadSiteNavigation } from '../lib/site/navigation';
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
const { mainNav, defaultCatalogHref } = await loadSiteNavigation();
---

<header class="header">
	<div class="container header__inner">
		<button type="button" class="header__menu-btn" aria-label={t.aria.openMenu} data-menu-toggle>
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
				<path d="M4 7h16M4 12h16M4 17h16" />
			</svg>
		</button>

		<a href="/" class="header__logo">
			<img src={brandLogo} alt={t.brand} width="180" height="40" decoding="async" />
		</a>

		<nav class="header__nav" aria-label={t.aria.mainNav}>
			<NavMenu items={mainNav} class="header__nav-list" />
		</nav>

		<form class="header__search" action={defaultCatalogHref} method="get" role="search">
			<label class="sr-only" for="header-search">{t.aria.searchRugs}</label>
			<input id="header-search" type="search" name="q" placeholder={t.searchPlaceholder} />
			<button type="submit" aria-label={t.aria.search}>
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
					<circle cx="11" cy="11" r="7" />
					<path d="M20 20l-3-3" />
				</svg>
			</button>
		</form>

		<div class="header__actions">
			<a href="#" class="header__action" aria-label={t.aria.account}>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
					<circle cx="12" cy="8" r="4" />
					<path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
				</svg>
			</a>
			<a href="/cart" class="header__action header__cart" aria-label={t.aria.cart}>
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
					<path d="M6 6h15l-1.5 9h-12z" />
					<circle cx="9" cy="20" r="1" />
					<circle cx="18" cy="20" r="1" />
					<path d="M6 6L5 3H2" />
				</svg>
				<span class="header__cart-count" data-cart-count>0</span>
			</a>
		</div>
	</div>

	<nav class="header__mobile" data-mobile-nav hidden>
		<NavMenu items={mainNav} class="header__mobile-list" subnavClass="header__mobile-subnav" />
	</nav>
</header>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-surface);
		border-bottom: 1px solid var(--color-border);
	}
	.header__inner {
		display: grid;
		grid-template-columns: auto 1fr auto auto;
		align-items: center;
		gap: 1.5rem;
		min-height: var(--header-height);
	}
	.header__menu-btn {
		display: none;
		padding: 0.5rem;
		border: none;
		background: none;
		cursor: pointer;
	}
	.header__logo {
		display: flex;
		align-items: center;
	}
	.header__logo img {
		display: block;
		height: 2.25rem;
		width: auto;
	}
	:global(.header__nav-list) {
		display: flex;
		gap: 1.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	:global(.header__nav-list > li) {
		position: relative;
	}
	:global(.header__nav-list a) {
		font-size: 0.8125rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		transition: color var(--transition);
	}
	:global(.header__nav-list a:hover) {
		color: var(--color-accent);
	}
	:global(.header__subnav) {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		min-width: 12rem;
		margin: 0;
		padding: 0.75rem 0;
		list-style: none;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
		z-index: 10;
	}
	:global(.header__subnav .header__subnav) {
		top: 0;
		left: 100%;
	}
	:global(.header__nav-list li.has-children:hover > .header__subnav),
	:global(.header__subnav li.has-children:hover > .header__subnav) {
		display: block;
	}
	:global(.header__subnav a) {
		display: block;
		padding: 0.45rem 1rem;
		text-transform: none;
		letter-spacing: 0;
		font-size: 0.875rem;
		white-space: nowrap;
	}
	.header__search {
		display: flex;
		max-width: 22rem;
		width: 100%;
		margin-inline: auto;
		border: 1px solid var(--color-border);
		background: var(--color-bg);
	}
	.header__search input {
		flex: 1;
		padding: 0.6rem 0.75rem;
		border: none;
		background: transparent;
		outline: none;
		font-size: 0.875rem;
	}
	.header__search button {
		padding: 0 0.75rem;
		border: none;
		background: none;
		cursor: pointer;
		color: var(--color-muted);
	}
	.header__actions {
		display: flex;
		gap: 0.75rem;
	}
	.header__action {
		display: grid;
		place-items: center;
		padding: 0.35rem;
		color: var(--color-ink);
	}
	.header__cart {
		position: relative;
	}
	.header__cart-count {
		position: absolute;
		top: 0;
		right: 0;
		min-width: 1rem;
		height: 1rem;
		padding: 0 0.2rem;
		font-size: 0.625rem;
		font-weight: 600;
		line-height: 1rem;
		text-align: center;
		background: var(--color-accent);
		color: white;
		border-radius: 50%;
	}
	.header__cart-count:empty,
	.header__cart-count[data-empty='true'] {
		display: none;
	}
	.header__mobile {
		border-top: 1px solid var(--color-border);
		background: var(--color-surface);
	}
	:global(.header__mobile-list),
	:global(.header__mobile-subnav) {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	:global(.header__mobile-list > li > a) {
		display: block;
		padding: 0.75rem 1rem;
		font-weight: 500;
		text-transform: uppercase;
		font-size: 0.875rem;
		letter-spacing: 0.04em;
	}
	:global(.header__mobile-subnav a) {
		display: block;
		padding: 0.5rem 1rem 0.5rem 1.75rem;
		font-size: 0.875rem;
		text-transform: none;
		letter-spacing: 0;
	}
	:global(.header__mobile-subnav .header__mobile-subnav a) {
		padding-left: 2.5rem;
	}
	@media (max-width: 1024px) {
		.header__inner {
			grid-template-columns: auto 1fr auto;
		}
		.header__nav {
			display: none;
		}
		.header__search {
			display: none;
		}
		.header__menu-btn {
			display: block;
		}
	}
</style>

<script>
	function updateCartCount() {
		const countEl = document.querySelector('[data-cart-count]');
		if (!countEl) return;
		try {
			const cart = JSON.parse(localStorage.getItem('womni-cart') || '[]');
			const total = cart.reduce((sum: number, item: { qty: number }) => sum + item.qty, 0);
			countEl.textContent = total > 0 ? String(total) : '';
			countEl.toggleAttribute('data-empty', total === 0);
		} catch {
			countEl.textContent = '';
		}
	}
	updateCartCount();
	window.addEventListener('cart-updated', updateCartCount);

	document.querySelector('[data-menu-toggle]')?.addEventListener('click', () => {
		const nav = document.querySelector('[data-mobile-nav]');
		nav?.toggleAttribute('hidden');
	});
</script>
