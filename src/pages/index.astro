---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import PageRenderer from '../components/PageRenderer.astro';
import { loadSiteNavigation } from '../lib/site/navigation';
import { loadPageConfig } from '../lib/site/pages';
import { mergePageConfig } from '../lib/site/page-defaults';
import { resolveRequestLocale } from '../lib/i18n/resolve-request-locale';
import { getLocalizedProducts, useTranslations } from '../i18n';

const requestLocale = resolveRequestLocale(Astro.url, Astro.currentLocale);
const t = useTranslations(requestLocale);
const editMode = Astro.url.searchParams.has('edit');
const remotePage = await loadPageConfig('home', { editMode });
const page = mergePageConfig('home', remotePage);
const { defaultCatalogHref } = await loadSiteNavigation();
const products = await getLocalizedProducts(requestLocale);
---

<BaseLayout title={t.brand} description={t.home.metaDescription}>
	<PageRenderer
		page={page}
		locale={requestLocale}
		defaultCatalogHref={defaultCatalogHref}
		products={products}
		homeDefaults={t.home}
		editMode={editMode}
	/>
</BaseLayout>

{editMode && (
	<style is:global>
		[data-block-id] {
			position: relative;
			transition: outline-color 0.15s ease;
		}
		[data-block-id].is-editor-selected {
			outline: 2px solid #987933;
			outline-offset: 4px;
		}
	</style>
	<script>
		window.addEventListener('message', (event) => {
			const data = event.data;
			if (!data || data.type !== 'SELECT_BLOCK' || !data.blockId) {
				return;
			}
			document.querySelectorAll('[data-block-id]').forEach((element) => {
				element.classList.remove('is-editor-selected');
			});
			const target = document.querySelector(`[data-block-id="${data.blockId}"]`);
			if (target) {
				target.classList.add('is-editor-selected');
				target.scrollIntoView({ behavior: 'smooth', block: 'center' });
			}
		});
	</script>
)}
