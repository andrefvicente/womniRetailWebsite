---
export const prerender = false;

import RemoteImage from '../../components/RemoteImage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categoryHref as buildCategoryHref, getCategoryBySlug } from '../../lib/db/categories';
import { buildOptionGroupsFromCombinations } from '../../lib/db/combinations';
import { getDatabase, hasDatabase } from '../../lib/db/bindings';
import { loadSiteNavigation } from '../../lib/site/navigation';
import { loadSiteFeatures } from '../../lib/site/features';
import { formatPrice, getLocalizedProduct, getLocalizedProducts, useTranslations } from '../../i18n';

const t = useTranslations(Astro.currentLocale);
const { defaultCatalogHref } = await loadSiteNavigation();
const { catalogMode } = await loadSiteFeatures();
const slug = Astro.params.slug;

if (!slug) {
	return Astro.redirect(defaultCatalogHref);
}

const product = await getLocalizedProduct(slug, Astro.currentLocale);

if (!product) {
	return Astro.redirect(defaultCatalogHref);
}

let categoryLabel = t.catalog.title;
let categoryHref = defaultCatalogHref;

if (product.categorySlug && hasDatabase()) {
	const db = getDatabase();
	const category = await getCategoryBySlug(db, product.categorySlug);
	if (category) {
		categoryLabel = category.name;
		categoryHref = buildCategoryHref(category.slug);
	}
}

const allLocalized = await getLocalizedProducts(Astro.currentLocale);
const related = allLocalized
	.filter(
		(p) =>
			p.slug !== product.slug &&
			(product.categorySlug ? p.categorySlug === product.categorySlug : true),
	)
	.slice(0, 4);
const discount =
	product.originalPrice && product.originalPrice > product.price
		? Math.round((1 - product.price / product.originalPrice) * 100)
		: null;
const productCombinations = product.combinations ?? [];
const optionGroups =
	product.optionGroups?.length
		? product.optionGroups
		: productCombinations.length
			? buildOptionGroupsFromCombinations(productCombinations)
			: [];
const productFeatures = product.features ?? [];

function imagesForCombination(combo: (typeof productCombinations)[number] | null | undefined) {
	if (combo?.images?.length) {
		return combo.images;
	}
	if (combo?.image) {
		return [combo.image];
	}
	return product.images;
}

const initialCombination =
	productCombinations.find((combo) => combo.available) ?? productCombinations[0] ?? null;
const displayImages = imagesForCombination(initialCombination);
---

<BaseLayout title={product.name} description={product.description}>
	<div class="container pdp">
		<Breadcrumbs
			items={[
				{ label: t.brand, href: '/' },
				{ label: categoryLabel, href: categoryHref },
				{ label: product.name },
			]}
		/>

		<div class="pdp__layout">
			<div class="pdp__gallery" data-pdp-gallery>
				<div class="pdp__main-image">
					<RemoteImage src={displayImages[0]} alt={product.name} width={800} height={1000} id="main-image" />
				</div>
				{displayImages.length > 1 && (
					<div class="pdp__thumbs" data-pdp-thumbs>
						{displayImages.map((img, i) => (
							<button
								type="button"
								class:list={['pdp__thumb', { active: i === 0 }]}
								data-thumb={img}
								aria-label={`${t.catalog.title} ${i + 1}`}
							>
								<RemoteImage src={img} alt="" width={120} height={150} />
							</button>
						))}
					</div>
				)}
			</div>

			<div class="pdp__info">
				{product.badge === 'sale' && discount && <span class="badge badge--sale">{t.product.save(discount)}</span>}
				{product.badge === 'new' && <span class="badge badge--new">{t.badges.new}</span>}
				<h1>{product.name}</h1>
				<div class="pdp__price">
					<span class="pdp__current" data-price-current>{formatPrice(product.price, Astro.currentLocale)}</span>
					{product.originalPrice && (
						<span class="pdp__was" data-price-was>{formatPrice(product.originalPrice, Astro.currentLocale)}</span>
					)}
				</div>

				{(optionGroups.length > 0 || !catalogMode) && (
					<div
						class="pdp__form"
						data-pdp-form
						data-slug={product.slug}
						data-name={product.name}
						data-price={product.price}
						data-image={displayImages[0]}
						data-added-msg={t.product.addedToCart}
						data-has-combinations={productCombinations.length > 0 ? 'true' : 'false'}
					>
						{optionGroups.map((group) => (
							<fieldset class="pdp__fieldset" data-option-fieldset={group.key}>
								<legend>{group.name}</legend>
								<div class="pdp__options" class:list={[{ 'pdp__options--color': group.groupType === 'color' }]}>
									{group.values.map((value, valueIndex) => (
										<label class="pdp__option" class:list={[{ 'pdp__option--color': group.groupType === 'color' }]}>
											<input
												type="radio"
												name={`opt-${group.key}`}
												value={value.id}
												data-option-group={group.key}
												data-option-label={value.name}
												checked={valueIndex === 0}
											/>
											{group.groupType === 'color' && value.color ? (
												<span
													class="pdp__color-swatch"
													style={`background:${value.color}`}
													title={value.name}
												/>
											) : (
												<span>{value.name}</span>
											)}
										</label>
									))}
								</div>
							</fieldset>
						))}

						{!catalogMode && (
							<>
								<div class="pdp__qty">
									<label for="qty">{t.product.quantity}</label>
									<input type="number" id="qty" name="qty" min="1" max="10" value="1" />
								</div>

								<button type="button" class="btn btn--accent pdp__add" data-add-to-cart-btn>
									{t.product.addToCart}
								</button>
							</>
						)}
					</div>
				)}

				<ul class="pdp__trust">
					{t.product.trust.map((line) => (
						<li>{line}</li>
					))}
				</ul>

				<details class="pdp__accordion" open>
					<summary>{t.product.description}</summary>
					<p>{product.description}</p>
				</details>
				{productFeatures.length > 0 && (
					<details class="pdp__accordion" open>
						<summary>{t.product.features}</summary>
						<dl class="pdp__features">
							{productFeatures.map((feature) => (
								<div class="pdp__feature">
									<dt>{feature.name}</dt>
									<dd>{feature.value}</dd>
								</div>
							))}
						</dl>
					</details>
				)}
				<details class="pdp__accordion">
					<summary>{t.product.care}</summary>
					<p>{product.care}</p>
				</details>
				<details class="pdp__accordion">
					<summary>{t.product.deliveryReturns}</summary>
					<p>{t.product.deliveryText}</p>
				</details>
			</div>
		</div>

		<section class="pdp__related">
			<h2>{t.product.related}</h2>
			<div class="product-grid">
				{related.map((p) => (
					<ProductCard product={p} />
				))}
			</div>
		</section>
	</div>
</BaseLayout>

<script define:vars={{ productCombinations, productOptionGroups: optionGroups, productImages: product.images, thumbAltPrefix: t.catalog.title, priceLocale: Astro.currentLocale ?? 'pt' }}>
	const combinations = productCombinations ?? [];
	const optionGroups = productOptionGroups ?? [];
	const fallbackImages = productImages ?? [];
	const hasCombinations = combinations.length > 0;
	const pdpRoot = document.querySelector('[data-pdp-form]');
	const pdpGallery = document.querySelector('[data-pdp-gallery]');
	const pdpThumbs = document.querySelector('[data-pdp-thumbs]');
	const addToCartBtn = document.querySelector('[data-add-to-cart-btn]');
	const priceCurrent = document.querySelector('[data-price-current]');
	const priceWas = document.querySelector('[data-price-was]');

	function imagesForCombination(combo) {
		if (combo?.images?.length) {
			return combo.images;
		}
		if (combo?.image) {
			return [combo.image];
		}
		return fallbackImages;
	}

	function bindThumbButtons() {
		document.querySelectorAll('[data-thumb]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const src = btn.getAttribute('data-thumb');
				const main = document.getElementById('main-image');
				if (main && src) {
					main.src = src;
				}
				document.querySelectorAll('.pdp__thumb').forEach((thumb) => thumb.classList.remove('active'));
				btn.classList.add('active');
			});
		});
	}

	function renderGallery(images) {
		const galleryImages = images.length ? images : fallbackImages;
		const main = document.getElementById('main-image');
		if (main && galleryImages[0]) {
			main.src = galleryImages[0];
		}

		if (!pdpGallery) {
			return;
		}

		let thumbs = pdpThumbs;
		if (galleryImages.length > 1) {
			if (!thumbs) {
				thumbs = document.createElement('div');
				thumbs.className = 'pdp__thumbs';
				thumbs.dataset.pdpThumbs = '';
				pdpGallery.appendChild(thumbs);
			}
			thumbs.innerHTML = galleryImages
				.map(
					(img, index) => `
						<button
							type="button"
							class="pdp__thumb${index === 0 ? ' active' : ''}"
							data-thumb="${img}"
							aria-label="${thumbAltPrefix} ${index + 1}"
						>
							<img src="${img}" alt="" width="120" height="150" loading="lazy" decoding="async" />
						</button>
					`,
				)
				.join('');
			thumbs.hidden = false;
			bindThumbButtons();
			return;
		}

		if (thumbs) {
			thumbs.innerHTML = '';
			thumbs.hidden = true;
		}
	}

	function updateImageDisplay() {
		const selected = selectedOptions();
		const combo = findCombinationForDisplay(selected);
		const images = imagesForCombination(combo);
		renderGallery(images);

		if (pdpRoot && images[0]) {
			pdpRoot.dataset.image = images[0];
		}
	}

	function formatPrice(amount) {
		const intlLocale = priceLocale === 'pt' ? 'pt-PT' : priceLocale;
		return new Intl.NumberFormat(intlLocale, {
			style: 'currency',
			currency: 'EUR',
			minimumFractionDigits: 2,
			maximumFractionDigits: 2,
		}).format(amount);
	}

	function comboSelections(combo) {
		if (combo.selections && Object.keys(combo.selections).length) {
			return combo.selections;
		}

		const resolved = {};
		for (const [groupKey, label] of Object.entries(combo.options ?? {})) {
			const group = optionGroups.find((entry) => entry.key === groupKey);
			const value = group?.values.find((entry) => entry.name === label);
			if (value) {
				resolved[groupKey] = value.id;
			}
		}
		return resolved;
	}

	function comboHasValue(combo, groupKey, attributeId) {
		const selections = comboSelections(combo);
		if (selections[groupKey] === attributeId) {
			return true;
		}

		const group = optionGroups.find((entry) => entry.key === groupKey);
		const value = group?.values.find((entry) => entry.id === attributeId);
		if (!value) {
			return false;
		}

		return combo.options?.[groupKey] === value.name;
	}

	function optionsMatch(comboOptions, comboSelections, selected) {
		if (Object.keys(comboSelections || {}).length) {
			return Object.entries(selected).every(
				([key, attributeId]) => comboSelections[key] === attributeId,
			);
		}
		return Object.entries(selected).every(
			([key, attributeId]) => {
				const input = pdpRoot?.querySelector(`[name="opt-${key}"][value="${attributeId}"]`);
				const label = input?.dataset?.optionLabel;
				return label != null && comboOptions[key] === label;
			},
		);
	}

	function selectedOptions() {
		const selected = {};
		for (const group of optionGroups) {
			const input = pdpRoot?.querySelector(`[name="opt-${group.key}"]:checked`);
			if (input?.value) {
				selected[group.key] = input.value;
			}
		}
		return selected;
	}

	function selectedOptionLabels() {
		const labels = {};
		for (const group of optionGroups) {
			const input = pdpRoot?.querySelector(`[name="opt-${group.key}"]:checked`);
			if (input?.dataset?.optionLabel) {
				labels[group.key] = input.dataset.optionLabel;
			}
		}
		return labels;
	}

	function matchCombination(selected, { requireAvailable = false } = {}) {
		if (!hasCombinations) {
			return null;
		}

		return (
			combinations.find(
				(combo) =>
					(!requireAvailable || combo.available) &&
					optionsMatch(combo.options, combo.selections, selected),
			) ?? null
		);
	}

	function findCombinationForDisplay(selected) {
		return matchCombination(selected);
	}

	function combinationExistsForValue(groupKey, attributeId) {
		if (!hasCombinations) {
			return true;
		}

		return combinations.some((combo) => comboHasValue(combo, groupKey, attributeId));
	}

	function ensureValidSelection(changedGroupKey) {
		if (!pdpRoot || !hasCombinations || !changedGroupKey) {
			return;
		}

		const selected = selectedOptions();
		if (findCombinationForDisplay(selected)) {
			return;
		}

		const changedValue = selected[changedGroupKey];
		if (!changedValue) {
			return;
		}

		const candidates = combinations.filter((combo) =>
			comboHasValue(combo, changedGroupKey, changedValue),
		);
		if (!candidates.length) {
			return;
		}

		const best = candidates
			.map((combo) => {
				const selections = comboSelections(combo);
				let score = 0;
				for (const group of optionGroups) {
					if (group.key === changedGroupKey) {
						continue;
					}
					if (selected[group.key] && selections[group.key] === selected[group.key]) {
						score += 1;
					}
				}
				return { combo, selections, score };
			})
			.sort((a, b) => b.score - a.score)[0];

		for (const group of optionGroups) {
			const attributeId = best.selections[group.key];
			if (!attributeId) {
				continue;
			}
			const input = pdpRoot.querySelector(`[name="opt-${group.key}"][value="${attributeId}"]`);
			if (input instanceof HTMLInputElement) {
				input.checked = true;
			}
		}
	}

	function refreshOptionStates() {
		if (!pdpRoot || !hasCombinations || !optionGroups.length) {
			return;
		}

		const selected = selectedOptions();

		for (const group of optionGroups) {
			pdpRoot.querySelectorAll(`[name="opt-${group.key}"]`).forEach((input) => {
				const label = input.closest('label');
				const exists = combinationExistsForValue(group.key, input.value);
				const combo = findCombinationForDisplay({
					...selected,
					[group.key]: input.value,
				});
				input.disabled = !exists;
				label?.classList.toggle('is-disabled', !exists);
				label?.classList.toggle('is-unavailable', exists && combo && !combo.available);
			});
		}
	}

	function updatePriceDisplay() {
		if (!pdpRoot) {
			return;
		}

		const selected = selectedOptions();
		const combo = findCombinationForDisplay(selected);

		if (combo) {
			pdpRoot.dataset.price = String(combo.price);
			if (priceCurrent) {
				priceCurrent.textContent = formatPrice(combo.price);
			}
			if (priceWas) {
				if (combo.originalPrice && combo.originalPrice > combo.price) {
					priceWas.textContent = formatPrice(combo.originalPrice);
					priceWas.hidden = false;
				} else {
					priceWas.hidden = true;
				}
			}
			const addBtn = pdpRoot.querySelector('.pdp__add');
			if (addBtn) {
				addBtn.disabled = false;
				addBtn.dataset.outOfStock = combo.available ? 'false' : 'true';
			}
			return;
		}

		const addBtn = pdpRoot.querySelector('.pdp__add');
		if (addBtn) {
			const allSelected = !optionGroups.length || optionGroups.every((group) => selected[group.key]);
			addBtn.disabled = !allSelected;
			addBtn.dataset.outOfStock = 'false';
		}

		if (hasCombinations) {
			const fallback = combinations.find((combo) => combo.available) ?? combinations[0];
			if (fallback) {
				pdpRoot.dataset.price = String(fallback.price);
				if (priceCurrent) {
					priceCurrent.textContent = formatPrice(fallback.price);
				}
			}
		}
	}

	function syncSelection() {
		refreshOptionStates();
		updatePriceDisplay();
		updateImageDisplay();
	}

	bindThumbButtons();

	if (pdpRoot) {
		pdpRoot.addEventListener('change', (event) => {
			const target = event.target;
			const groupKey =
				target instanceof HTMLInputElement ? target.dataset.optionGroup : undefined;
			if (groupKey) {
				ensureValidSelection(groupKey);
			}
			syncSelection();
		});
		syncSelection();
	}

	if (addToCartBtn && pdpRoot) {
		addToCartBtn.addEventListener('click', () => {
		const slug = pdpRoot.dataset.slug;
		const name = pdpRoot.dataset.name;
		const image = pdpRoot.dataset.image;
		const addedMsg = pdpRoot.dataset.addedMsg;
		const qty = Number(pdpRoot.querySelector('[name="qty"]')?.value || 1);
		const selected = selectedOptions();

		let linePrice = Number(pdpRoot.dataset.price);
		let combinationId = null;

		if (hasCombinations) {
			if (optionGroups.some((group) => !selected[group.key])) {
				return;
			}
			const combo = findCombinationForDisplay(selected);
			if (!combo) {
				return;
			}
			linePrice = combo.price;
			combinationId = combo.id ?? null;
		} else if (!Number.isFinite(linePrice) || linePrice <= 0) {
			return;
		}
		const id = combinationId ? `${slug}-${combinationId}` : `${slug}-${Object.values(selected).join('-')}`;

		const optionLabels = optionGroups.map((group) => ({
			key: group.key,
			name: group.name,
			value: selectedOptionLabels()[group.key] ?? '',
		}));

		const cart = JSON.parse(localStorage.getItem('womni-cart') || '[]');
		const existing = cart.find((item) => item.id === id);
		if (existing) existing.qty += qty;
		else {
			cart.push({
				id,
				slug,
				name,
				price: linePrice,
				image,
				qty,
				combinationId,
				selections: optionGroups.length ? selected : undefined,
				options: optionGroups.length ? selectedOptionLabels() : undefined,
				optionLabels: optionGroups.length ? optionLabels : undefined,
			});
		}
		localStorage.setItem('womni-cart', JSON.stringify(cart));
		window.dispatchEvent(new Event('cart-updated'));

		const btn = addToCartBtn;
		if (btn && addedMsg) {
			const original = btn.textContent;
			btn.textContent = addedMsg;
			setTimeout(() => {
				btn.textContent = original;
			}, 2000);
		}
	});
	}
</script>

<style>
	.pdp {
		padding: 1.5rem 0 4rem;
	}
	.pdp__layout {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: 3rem;
		margin-top: 2rem;
	}
	.pdp__main-image {
		background: #f0eeeb;
		aspect-ratio: 4 / 5;
	}
	.pdp__main-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.pdp__thumbs {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}
	.pdp__thumb {
		padding: 0;
		border: 2px solid transparent;
		background: none;
		cursor: pointer;
		width: 4.5rem;
		overflow: hidden;
	}
	.pdp__thumb.active,
	.pdp__thumb:hover {
		border-color: var(--color-ink);
	}
	.pdp__thumb img {
		aspect-ratio: 4 / 5;
		object-fit: cover;
	}
	.pdp__info h1 {
		margin: 0.75rem 0 0;
		font-family: var(--font-display);
		font-size: 2.25rem;
		font-weight: 500;
	}
	.pdp__price {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		margin-top: 1rem;
	}
	.pdp__features {
		margin: 0.75rem 0 0;
		display: grid;
		gap: 0.65rem;
	}
	.pdp__feature {
		display: grid;
		grid-template-columns: minmax(8rem, 40%) 1fr;
		gap: 1rem;
		font-size: 0.875rem;
	}
	.pdp__feature dt {
		margin: 0;
		color: var(--color-muted);
		font-weight: 500;
	}
	.pdp__feature dd {
		margin: 0;
		color: var(--color-ink);
	}
	.pdp__current {
		font-size: 1.5rem;
		font-weight: 600;
	}
	.pdp__was {
		font-size: 1.125rem;
		color: var(--color-muted);
		text-decoration: line-through;
	}
	.pdp__fieldset {
		margin: 0 0 1.25rem;
		padding: 0;
		border: none;
	}
	.pdp__fieldset legend {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.5rem;
	}
	.pdp__options {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.pdp__option {
		cursor: pointer;
	}
	.pdp__option input {
		position: absolute;
		opacity: 0;
	}
	.pdp__option span {
		display: block;
		padding: 0.5rem 0.85rem;
		border: 1px solid var(--color-border);
		font-size: 0.8125rem;
		transition: border-color var(--transition), background var(--transition);
	}
	.pdp__option input:checked + span {
		border-color: var(--color-ink);
		background: var(--color-ink);
		color: white;
	}
	.pdp__option input:checked + .pdp__color-swatch {
		outline: 2px solid var(--color-ink);
		outline-offset: 2px;
	}
	.pdp__color-swatch {
		display: block;
		width: 2rem;
		height: 2rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
	}
	.pdp__option.is-disabled span,
	.pdp__option.is-disabled .pdp__color-swatch {
		opacity: 0.35;
		cursor: not-allowed;
	}
	.pdp__qty {
		margin-bottom: 1.25rem;
	}
	.pdp__qty label {
		display: block;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.35rem;
	}
	.pdp__qty input {
		width: 4rem;
		padding: 0.5rem;
		border: 1px solid var(--color-border);
	}
	.pdp__add {
		width: 100%;
		padding: 1rem;
	}
