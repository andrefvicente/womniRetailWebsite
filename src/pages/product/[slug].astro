---
export const prerender = false;

import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categoryHref as buildCategoryHref, getCategoryBySlug } from '../../lib/db/categories';
import { buildOptionGroupsFromCombinations } from '../../lib/db/combinations';
import { getDatabase, hasDatabase } from '../../lib/db/bindings';
import { loadSiteNavigation } from '../../lib/site/navigation';
import { formatPrice, getLocalizedProduct, getLocalizedProducts, useTranslations } from '../../i18n';

const t = useTranslations(Astro.currentLocale);
const { defaultCatalogHref } = await loadSiteNavigation();
const slug = Astro.params.slug;

if (!slug) {
	return Astro.redirect(defaultCatalogHref);
}

const product = await getLocalizedProduct(slug, Astro.currentLocale);

if (!product) {
	return Astro.redirect(defaultCatalogHref);
}

let categoryLabel = t.catalog.title;
let categoryHref = defaultCatalogHref;

if (product.categorySlug && hasDatabase()) {
	const db = getDatabase();
	const category = await getCategoryBySlug(db, product.categorySlug);
	if (category) {
		categoryLabel = category.name;
		categoryHref = buildCategoryHref(category.slug);
	}
}

const allLocalized = await getLocalizedProducts(Astro.currentLocale);
const related = allLocalized
	.filter(
		(p) =>
			p.slug !== product.slug &&
			(product.categorySlug ? p.categorySlug === product.categorySlug : true),
	)
	.slice(0, 4);
const discount =
	product.originalPrice && product.originalPrice > product.price
		? Math.round((1 - product.price / product.originalPrice) * 100)
		: null;
const productCombinations = product.combinations ?? [];
const optionGroups =
	product.optionGroups?.length
		? product.optionGroups
		: productCombinations.length
			? buildOptionGroupsFromCombinations(productCombinations)
			: [];
const productFeatures = product.features ?? [];
---

<BaseLayout title={product.name} description={product.description}>
	<div class="container pdp">
		<Breadcrumbs
			items={[
				{ label: t.brand, href: '/' },
				{ label: categoryLabel, href: categoryHref },
				{ label: product.name },
			]}
		/>

		<div class="pdp__layout">
			<div class="pdp__gallery">
				<div class="pdp__main-image">
					<Image src={product.images[0]} alt={product.name} width={800} height={1000} id="main-image" />
				</div>
				{product.images.length > 1 && (
					<div class="pdp__thumbs">
						{product.images.map((img, i) => (
							<button
								type="button"
								class:list={['pdp__thumb', { active: i === 0 }]}
								data-thumb={img}
								aria-label={`${t.catalog.title} ${i + 1}`}
							>
								<Image src={img} alt="" width={120} height={150} />
							</button>
						))}
					</div>
				)}
			</div>

			<div class="pdp__info">
				{product.badge === 'sale' && discount && <span class="badge badge--sale">{t.product.save(discount)}</span>}
				{product.badge === 'new' && <span class="badge badge--new">{t.badges.new}</span>}
				<h1>{product.name}</h1>
				<div class="pdp__price">
					<span class="pdp__current" data-price-current>{formatPrice(product.price, Astro.currentLocale)}</span>
					{product.originalPrice && (
						<span class="pdp__was" data-price-was>{formatPrice(product.originalPrice, Astro.currentLocale)}</span>
					)}
				</div>

				<form
					class="pdp__form"
					data-add-to-cart
					data-slug={product.slug}
					data-name={product.name}
					data-price={product.price}
					data-image={product.image}
					data-added-msg={t.product.addedToCart}
					data-has-combinations={productCombinations.length > 0 ? 'true' : 'false'}
				>
					{optionGroups.map((group, groupIndex) => (
						<fieldset class="pdp__fieldset" data-option-fieldset={group.key}>
							<legend>{group.name}</legend>
							<div class="pdp__options" class:list={[{ 'pdp__options--color': group.groupType === 'color' }]}>
								{group.values.map((value, valueIndex) => (
									<label class="pdp__option" class:list={[{ 'pdp__option--color': group.groupType === 'color' }]}>
										<input
											type="radio"
											name={`opt-${group.key}`}
											value={value.id}
											data-option-group={group.key}
											data-option-label={value.name}
											checked={valueIndex === 0}
											required
										/>
										{group.groupType === 'color' && value.color ? (
											<span
												class="pdp__color-swatch"
												style={`background:${value.color}`}
												title={value.name}
											/>
										) : (
											<span>{value.name}</span>
										)}
									</label>
								))}
							</div>
						</fieldset>
					))}

					<div class="pdp__qty">
						<label for="qty">{t.product.quantity}</label>
						<input type="number" id="qty" name="qty" min="1" max="10" value="1" />
					</div>

					<button type="submit" class="btn btn--accent pdp__add">{t.product.addToCart}</button>
				</form>

				<ul class="pdp__trust">
					{t.product.trust.map((line) => (
						<li>{line}</li>
					))}
				</ul>

				<details class="pdp__accordion" open>
					<summary>{t.product.description}</summary>
					<p>{product.description}</p>
				</details>
				{productFeatures.length > 0 && (
					<details class="pdp__accordion" open>
						<summary>{t.product.features}</summary>
						<dl class="pdp__features">
							{productFeatures.map((feature) => (
								<div class="pdp__feature">
									<dt>{feature.name}</dt>
									<dd>{feature.value}</dd>
								</div>
							))}
						</dl>
					</details>
				)}
				<details class="pdp__accordion">
					<summary>{t.product.care}</summary>
					<p>{product.care}</p>
				</details>
				<details class="pdp__accordion">
					<summary>{t.product.deliveryReturns}</summary>
					<p>{t.product.deliveryText}</p>
				</details>
			</div>
		</div>

		<section class="pdp__related">
			<h2>{t.product.related}</h2>
			<div class="product-grid">
				{related.map((p) => (
					<ProductCard product={p} />
				))}
			</div>
		</section>
	</div>
</BaseLayout>

<script define:vars={{ productCombinations, productOptionGroups: optionGroups, priceLocale: Astro.currentLocale ?? 'pt' }}>
	const combinations = productCombinations ?? [];
	const optionGroups = productOptionGroups ?? [];
	const hasCombinations = combinations.length > 0;
	const form = document.querySelector('[data-add-to-cart]');
	const priceCurrent = document.querySelector('[data-price-current]');
	const priceWas = document.querySelector('[data-price-was]');

	function formatPrice(amount) {
		const intlLocale = priceLocale === 'pt' ? 'pt-PT' : priceLocale;
		return new Intl.NumberFormat(intlLocale, {
			style: 'currency',
			currency: 'EUR',
			maximumFractionDigits: 0,
		}).format(amount);
	}

	function optionsMatch(comboOptions, comboSelections, selected) {
		if (Object.keys(comboSelections || {}).length) {
			return Object.entries(selected).every(
				([key, attributeId]) => comboSelections[key] === attributeId,
			);
		}
		return Object.entries(selected).every(
			([key, attributeId]) => {
				const input = form?.querySelector(`[name="opt-${key}"][value="${attributeId}"]`);
				const label = input?.dataset?.optionLabel;
				return label != null && comboOptions[key] === label;
			},
		);
	}

	function selectedOptions() {
		const selected = {};
		for (const group of optionGroups) {
			const input = form?.querySelector(`[name="opt-${group.key}"]:checked`);
			if (input?.value) {
				selected[group.key] = input.value;
			}
		}
		return selected;
	}

	function selectedOptionLabels() {
		const labels = {};
		for (const group of optionGroups) {
			const input = form?.querySelector(`[name="opt-${group.key}"]:checked`);
			if (input?.dataset?.optionLabel) {
				labels[group.key] = input.dataset.optionLabel;
			}
		}
		return labels;
	}

	function matchCombination(selected, { requireAvailable = false } = {}) {
		if (!hasCombinations) {
			return null;
		}

		return (
			combinations.find(
				(combo) =>
					(!requireAvailable || combo.available) &&
					optionsMatch(combo.options, combo.selections, selected),
			) ?? null
		);
	}

	function findCombinationForDisplay(selected) {
		return matchCombination(selected);
	}

	function combinationExistsForValue(groupKey, attributeId, selected) {
		if (!hasCombinations) {
			return true;
		}

		const trial = { ...selected, [groupKey]: attributeId };
		return Boolean(findCombinationForDisplay(trial));
	}

	function refreshOptionStates() {
		if (!form || !hasCombinations || !optionGroups.length) {
			return;
		}

		const selected = selectedOptions();

		for (const group of optionGroups) {
			form.querySelectorAll(`[name="opt-${group.key}"]`).forEach((input) => {
				const label = input.closest('label');
				const exists = combinationExistsForValue(group.key, input.value, selected);
				const combo = findCombinationForDisplay({
					...selected,
					[group.key]: input.value,
				});
				input.disabled = !exists;
				label?.classList.toggle('is-disabled', !exists);
				label?.classList.toggle('is-unavailable', exists && combo && !combo.available);
			});
		}
	}

	function updatePriceDisplay() {
		if (!form) {
			return;
		}

		const selected = selectedOptions();
		const combo = findCombinationForDisplay(selected);

		if (combo) {
			form.dataset.price = String(combo.price);
			if (priceCurrent) {
				priceCurrent.textContent = formatPrice(combo.price);
			}
			if (priceWas) {
				if (combo.originalPrice && combo.originalPrice > combo.price) {
					priceWas.textContent = formatPrice(combo.originalPrice);
					priceWas.hidden = false;
				} else {
					priceWas.hidden = true;
				}
			}
			const addBtn = form.querySelector('.pdp__add');
			if (addBtn) {
				addBtn.disabled = false;
				addBtn.dataset.outOfStock = combo.available ? 'false' : 'true';
			}
			return;
		}

		const addBtn = form.querySelector('.pdp__add');
		if (addBtn) {
			const allSelected = !optionGroups.length || optionGroups.every((group) => selected[group.key]);
			addBtn.disabled = !allSelected;
			addBtn.dataset.outOfStock = 'false';
		}

		if (hasCombinations) {
			const fallback = combinations.find((combo) => combo.available) ?? combinations[0];
			if (fallback) {
				form.dataset.price = String(fallback.price);
				if (priceCurrent) {
					priceCurrent.textContent = formatPrice(fallback.price);
				}
			}
		}
	}

	function syncSelection() {
		refreshOptionStates();
		updatePriceDisplay();
	}

	document.querySelectorAll('[data-thumb]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const src = btn.getAttribute('data-thumb');
			const main = document.getElementById('main-image');
			if (main && src) main.src = src;
			document.querySelectorAll('.pdp__thumb').forEach((t) => t.classList.remove('active'));
			btn.classList.add('active');
		});
	});

	document.querySelector('[data-add-to-cart]')?.addEventListener('change', syncSelection);
	syncSelection();

	document.querySelector('[data-add-to-cart]')?.addEventListener('submit', (e) => {
		e.preventDefault();
		const form = e.target;
		const slug = form.dataset.slug;
		const name = form.dataset.name;
		const image = form.dataset.image;
		const addedMsg = form.dataset.addedMsg;
		const qty = Number(form.querySelector('[name="qty"]')?.value || 1);
		const selected = selectedOptions();

		let linePrice = Number(form.dataset.price);
		let combinationId = null;

		if (hasCombinations) {
			if (optionGroups.some((group) => !selected[group.key])) {
				return;
			}
			const combo = findCombinationForDisplay(selected);
			if (!combo) {
				return;
			}
			linePrice = combo.price;
			combinationId = combo.id ?? null;
		} else if (!Number.isFinite(linePrice) || linePrice <= 0) {
			return;
		}
		const id = combinationId ? `${slug}-${combinationId}` : `${slug}-${Object.values(selected).join('-')}`;

		const optionLabels = optionGroups.map((group) => ({
			key: group.key,
			name: group.name,
			value: selectedOptionLabels()[group.key] ?? '',
		}));

		const cart = JSON.parse(localStorage.getItem('womni-cart') || '[]');
		const existing = cart.find((item) => item.id === id);
		if (existing) existing.qty += qty;
		else {
			cart.push({
				id,
				slug,
				name,
				price: linePrice,
				image,
				qty,
				combinationId,
				selections: optionGroups.length ? selected : undefined,
				options: optionGroups.length ? selectedOptionLabels() : undefined,
				optionLabels: optionGroups.length ? optionLabels : undefined,
			});
		}
		localStorage.setItem('womni-cart', JSON.stringify(cart));
		window.dispatchEvent(new Event('cart-updated'));

		const btn = form.querySelector('.pdp__add');
		if (btn && addedMsg) {
			const original = btn.textContent;
			btn.textContent = addedMsg;
			setTimeout(() => {
				btn.textContent = original;
			}, 2000);
		}
	});
</script>

<style>
	.pdp {
		padding: 1.5rem 0 4rem;
	}
	.pdp__layout {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: 3rem;
		margin-top: 2rem;
	}
	.pdp__main-image {
		background: #f0eeeb;
		aspect-ratio: 4 / 5;
	}
	.pdp__main-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.pdp__thumbs {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}
	.pdp__thumb {
		padding: 0;
		border: 2px solid transparent;
		background: none;
		cursor: pointer;
		width: 4.5rem;
		overflow: hidden;
	}
	.pdp__thumb.active,
	.pdp__thumb:hover {
		border-color: var(--color-ink);
	}
	.pdp__thumb img {
		aspect-ratio: 4 / 5;
		object-fit: cover;
	}
	.pdp__info h1 {
		margin: 0.75rem 0 0;
		font-family: var(--font-display);
		font-size: 2.25rem;
		font-weight: 500;
	}
	.pdp__price {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		margin-top: 1rem;
	}
	.pdp__features {
		margin: 0.75rem 0 0;
		display: grid;
		gap: 0.65rem;
	}
	.pdp__feature {
		display: grid;
		grid-template-columns: minmax(8rem, 40%) 1fr;
		gap: 1rem;
		font-size: 0.875rem;
	}
	.pdp__feature dt {
		margin: 0;
		color: var(--color-muted);
		font-weight: 500;
	}
	.pdp__feature dd {
		margin: 0;
		color: var(--color-ink);
	}
	.pdp__current {
		font-size: 1.5rem;
		font-weight: 600;
	}
	.pdp__was {
		font-size: 1.125rem;
		color: var(--color-muted);
		text-decoration: line-through;
	}
	.pdp__fieldset {
		margin: 0 0 1.25rem;
		padding: 0;
		border: none;
	}
	.pdp__fieldset legend {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.5rem;
	}
	.pdp__options {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.pdp__option {
		cursor: pointer;
	}
	.pdp__option input {
		position: absolute;
		opacity: 0;
	}
	.pdp__option span {
		display: block;
		padding: 0.5rem 0.85rem;
		border: 1px solid var(--color-border);
		font-size: 0.8125rem;
		transition: border-color var(--transition), background var(--transition);
	}
	.pdp__option input:checked + span {
		border-color: var(--color-ink);
		background: var(--color-ink);
		color: white;
	}
	.pdp__option input:checked + .pdp__color-swatch {
		outline: 2px solid var(--color-ink);
		outline-offset: 2px;
	}
	.pdp__color-swatch {
		display: block;
		width: 2rem;
		height: 2rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
	}
	.pdp__option.is-disabled span,
	.pdp__option.is-disabled .pdp__color-swatch {
		opacity: 0.35;
		cursor: not-allowed;
	}
	.pdp__qty {
		margin-bottom: 1.25rem;
	}
	.pdp__qty label {
		display: block;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.35rem;
	}
	.pdp__qty input {
		width: 4rem;
		padding: 0.5rem;
		border: 1px solid var(--color-border);
	}
	.pdp__add {
		width: 100%;
		padding: 1rem;
	}
	.pdp__trust {
		margin: 1.5rem 0 0;
		padding: 1rem 0 0;
		border-top: 1px solid var(--color-border);
		list-style: none;
		font-size: 0.875rem;
		color: var(--color-muted);
	}
	.pdp__trust li + li {
		margin-top: 0.35rem;
	}
	.pdp__accordion {
		margin-top: 0.75rem;
		border-top: 1px solid var(--color-border);
		padding-top: 0.75rem;
	}
	.pdp__accordion summary {
		font-weight: 600;
		cursor: pointer;
	}
	.pdp__accordion p {
		margin: 0.75rem 0 0;
		color: var(--color-muted);
		line-height: 1.6;
	}
	.pdp__related {
		margin-top: 4rem;
		padding-top: 3rem;
		border-top: 1px solid var(--color-border);
	}
	.pdp__related h2 {
		margin: 0 0 2rem;
		font-family: var(--font-display);
		font-size: 2rem;
		font-weight: 500;
	}
	.pdp__related .product-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}
	@media (max-width: 900px) {
		.pdp__layout {
			grid-template-columns: 1fr;
		}
		.pdp__related .product-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
