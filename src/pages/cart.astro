---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { loadSiteNavigation } from '../lib/site/navigation';
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
const { defaultCatalogHref } = await loadSiteNavigation();

const cartI18n = {
	loading: t.cart.loading,
	empty: t.cart.empty,
	shopRugs: t.cart.shopRugs,
	size: t.cart.size,
	color: t.cart.color,
	qty: t.cart.qty,
	remove: t.cart.remove,
	product: t.cart.product,
	price: t.cart.price,
	quantity: t.cart.quantity,
		lineTotal: t.cart.lineTotal,
		image: t.cart.image,
		decreaseQty: 'Diminuir quantidade',
		increaseQty: 'Aumentar quantidade',
		subtotal: t.cart.subtotal,
	shipping: t.cart.shipping,
	shippingCalc: t.cart.shippingCalc,
	shippingFree: t.cart.shippingFree,
	total: t.cart.total,
	freeShippingNote: t.cart.freeShippingNote,
	checkout: t.cart.checkout,
	continueShopping: t.cart.continueShopping,
	locale: 'pt-PT',
	currency: 'EUR',
	freeShippingMin: 99,
	shippingCost: 9.95,
};
---

<BaseLayout title={t.cart.title} description={t.cart.metaDescription}>
	<div class="container cart-page">
		<Breadcrumbs items={[{ label: t.brand, href: '/' }, { label: t.cart.title }]} />
		<h1>{t.cart.title}</h1>

		<div class="cart-page__layout">
			<div data-cart-items class="cart-page__items">
				<p class="cart-page__loading">{t.cart.loading}</p>
			</div>
			<aside class="cart-page__summary" data-cart-summary hidden>
				<h2>{t.cart.summary}</h2>
				<div class="cart-page__row">
					<span>{t.cart.subtotal}</span>
					<span data-subtotal>0 €</span>
				</div>
				<div class="cart-page__row">
					<span>{t.cart.shipping}</span>
					<span data-shipping>{t.cart.shippingCalc}</span>
				</div>
				<div class="cart-page__row cart-page__row--total">
					<span>{t.cart.total}</span>
					<span data-total>0 €</span>
				</div>
				<p class="cart-page__note">{t.cart.freeShippingNote}</p>
				<button type="button" class="btn btn--accent cart-page__checkout">{t.cart.checkout}</button>
				<a href={defaultCatalogHref} class="cart-page__continue">{t.cart.continueShopping}</a>
			</aside>
		</div>

		<div class="cart-page__empty" data-cart-empty hidden>
			<p>{t.cart.empty}</p>
			<a href={defaultCatalogHref} class="btn">{t.cart.shopRugs}</a>
		</div>
	</div>
</BaseLayout>

<script define:vars={{ cartI18n }}>
	function formatPrice(n) {
		return new Intl.NumberFormat(cartI18n.locale, {
			style: 'currency',
			currency: cartI18n.currency,
			maximumFractionDigits: 0,
		}).format(n);
	}

	function formatSizeValue(value) {
		const match = String(value).trim().match(/^0*(\d+)\s*[x×]\s*0*(\d+)/i);
		if (match) {
			return `${match[1]} × ${match[2]} cm`;
		}
		return String(value).trim();
	}

	function variantEntries(item) {
		if (item.optionLabels?.length) {
			return item.optionLabels
				.filter((entry) => entry.value)
				.map((entry) => ({
					name: entry.name,
					value:
						entry.name.toLowerCase().includes('tamanho') ||
						entry.key === 'g1' ||
						entry.key === 'size'
							? formatSizeValue(entry.value)
							: entry.value,
				}));
		}
		if (item.options && Object.keys(item.options).length) {
			return Object.entries(item.options).map(([key, value]) => ({
				name: key.startsWith('g') ? (key === 'g1' ? cartI18n.size : cartI18n.color) : key,
				value: key === 'g1' || key === 'size' ? formatSizeValue(value) : value,
			}));
		}
		const entries = [];
		if (item.size) {
			entries.push({ name: cartI18n.size, value: formatSizeValue(item.size) });
		}
		if (item.color) {
			entries.push({ name: cartI18n.color, value: item.color });
		}
		return entries;
	}

	function formatVariantHtml(item) {
		const entries = variantEntries(item);
		if (!entries.length) {
			return '';
		}
		return `<p class="cart-table__meta">${entries
			.map(
				(entry) =>
					`<span class="cart-table__meta-item"><span class="cart-table__meta-label">${entry.name}</span><span class="cart-table__meta-value">${entry.value}</span></span>`,
			)
			.join('')}</p>`;
	}

	function renderCart() {
		const itemsEl = document.querySelector('[data-cart-items]');
		const summaryEl = document.querySelector('[data-cart-summary]');
		const emptyEl = document.querySelector('[data-cart-empty]');
		const subtotalEl = document.querySelector('[data-subtotal]');
		const totalEl = document.querySelector('[data-total]');
		const shippingEl = document.querySelector('[data-shipping]');

		const cart = JSON.parse(localStorage.getItem('womni-cart') || '[]');

		if (!cart.length) {
			if (itemsEl) itemsEl.innerHTML = '';
			summaryEl?.setAttribute('hidden', '');
			emptyEl?.removeAttribute('hidden');
			return;
		}

		emptyEl?.setAttribute('hidden', '');
		summaryEl?.removeAttribute('hidden');

		const subtotal = cart.reduce((sum, item) => sum + item.price * item.qty, 0);
		const shipping = subtotal >= cartI18n.freeShippingMin ? 0 : cartI18n.shippingCost;
		const total = subtotal + shipping;

		if (itemsEl) {
			const rows = cart
				.map((item) => {
					const variantHtml = formatVariantHtml(item);
					return `
				<tr class="cart-table__row" data-id="${item.id}">
					<td class="cart-table__cell cart-table__cell--image">
						<a href="/product/${item.slug}" class="cart-table__image-link" tabindex="-1" aria-hidden="true">
							<img src="${item.image}" alt="" width="72" height="90" loading="lazy" />
						</a>
					</td>
					<td class="cart-table__cell cart-table__cell--product">
						<a href="/product/${item.slug}" class="cart-table__name">${item.name}</a>
						${variantHtml}
					</td>
					<td class="cart-table__cell cart-table__cell--price">
						<div class="cart-table__cell-inner cart-table__cell-inner--end">
							<span class="cart-table__money">${formatPrice(item.price)}</span>
						</div>
					</td>
					<td class="cart-table__cell cart-table__cell--qty">
						<div class="cart-table__cell-inner cart-table__cell-inner--center">
							<div class="cart-qty" data-qty-control data-id="${item.id}">
								<button type="button" class="cart-qty__btn" data-qty-dec aria-label="${cartI18n.decreaseQty}">
									<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/></svg>
								</button>
								<input type="number" min="1" max="10" value="${item.qty}" data-qty aria-label="${cartI18n.quantity}" readonly />
								<button type="button" class="cart-qty__btn" data-qty-inc aria-label="${cartI18n.increaseQty}">
									<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
								</button>
							</div>
						</div>
					</td>
					<td class="cart-table__cell cart-table__cell--total">
						<div class="cart-table__cell-inner cart-table__cell-inner--end">
							<span class="cart-table__money cart-table__money--total">${formatPrice(item.price * item.qty)}</span>
						</div>
					</td>
					<td class="cart-table__cell cart-table__cell--remove">
						<div class="cart-table__cell-inner cart-table__cell-inner--center">
							<button type="button" class="cart-table__remove" data-remove="${item.id}" aria-label="${cartI18n.remove} ${item.name}">
								<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
									<path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6" />
									<path d="M10 11v6M14 11v6" />
								</svg>
							</button>
						</div>
					</td>
				</tr>
			`;
				})
				.join('');

			itemsEl.innerHTML = `
				<div class="cart-table-wrap">
					<table class="cart-table">
						<colgroup>
							<col class="cart-table__col cart-table__col--image" />
							<col class="cart-table__col cart-table__col--product" />
							<col class="cart-table__col cart-table__col--price" />
							<col class="cart-table__col cart-table__col--qty" />
							<col class="cart-table__col cart-table__col--total" />
							<col class="cart-table__col cart-table__col--remove" />
						</colgroup>
						<thead>
							<tr>
								<th scope="col" class="cart-table__head cart-table__head--image"><span class="sr-only">${cartI18n.image}</span></th>
								<th scope="col" class="cart-table__head cart-table__head--product">${cartI18n.product}</th>
								<th scope="col" class="cart-table__head cart-table__head--price">${cartI18n.price}</th>
								<th scope="col" class="cart-table__head cart-table__head--qty">${cartI18n.quantity}</th>
								<th scope="col" class="cart-table__head cart-table__head--total">${cartI18n.lineTotal}</th>
								<th scope="col" class="cart-table__head cart-table__head--remove"><span class="sr-only">${cartI18n.remove}</span></th>
							</tr>
						</thead>
						<tbody>${rows}</tbody>
					</table>
				</div>
			`;
		}

		if (subtotalEl) subtotalEl.textContent = formatPrice(subtotal);
		if (totalEl) totalEl.textContent = formatPrice(total);
		if (shippingEl)
			shippingEl.textContent = shipping === 0 ? cartI18n.shippingFree : formatPrice(shipping);

		itemsEl?.querySelectorAll('[data-qty-control]').forEach((control) => {
			const id = control.getAttribute('data-id');
			const input = control.querySelector('[data-qty]');
			const dec = control.querySelector('[data-qty-dec]');
			const inc = control.querySelector('[data-qty-inc]');

			function updateQty(next) {
				const cart = JSON.parse(localStorage.getItem('womni-cart') || '[]');
				const item = cart.find((i) => i.id === id);
				if (!item) return;
				item.qty = Math.min(10, Math.max(1, next));
				localStorage.setItem('womni-cart', JSON.stringify(cart));
				window.dispatchEvent(new Event('cart-updated'));
				renderCart();
			}

			input?.addEventListener('change', () => {
				updateQty(Number(input.value));
			});

			dec?.addEventListener('click', () => {
				updateQty(Number(input?.value || 1) - 1);
			});

			inc?.addEventListener('click', () => {
				updateQty(Number(input?.value || 1) + 1);
			});
		});

		itemsEl?.querySelectorAll('[data-remove]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const id = btn.getAttribute('data-remove');
				let cart = JSON.parse(localStorage.getItem('womni-cart') || '[]');
				cart = cart.filter((i) => i.id !== id);
				localStorage.setItem('womni-cart', JSON.stringify(cart));
				window.dispatchEvent(new Event('cart-updated'));
				renderCart();
			});
		});
	}

	renderCart();
</script>

<style>
	.cart-page {
		padding: 1.5rem 0 4rem;
	}
	.cart-page h1 {
		margin: 1.5rem 0 2rem;
		font-family: var(--font-display);
		font-size: 2.5rem;
		font-weight: 500;
	}
	.cart-page__layout {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 3rem;
		align-items: start;
	}
	.cart-page__summary {
		padding: 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		position: sticky;
		top: calc(var(--header-height) + 1rem);
	}
	.cart-page__summary h2 {
		margin: 0 0 1.25rem;
		font-size: 1rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	.cart-page__row {
		display: flex;
		justify-content: space-between;
		padding: 0.5rem 0;
		font-size: 0.9375rem;
	}
	.cart-page__row--total {
		margin-top: 0.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--color-border);
		font-weight: 600;
		font-size: 1.125rem;
	}
	.cart-page__note {
		margin: 0.75rem 0 1.25rem;
		font-size: 0.8125rem;
		color: var(--color-muted);
	}
	.cart-page__checkout {
		width: 100%;
	}
	.cart-page__continue {
		display: block;
		margin-top: 1rem;
		text-align: center;
		font-size: 0.875rem;
		text-decoration: underline;
		color: var(--color-muted);
	}
	.cart-page__empty {
		text-align: center;
		padding: 4rem 0;
	}
	.cart-page__empty p {
		margin-bottom: 1.5rem;
		color: var(--color-muted);
	}

	/* JS-rendered cart rows — must be :global (no Astro scope attribute) */
	.cart-page :global(.cart-table-wrap) {
		overflow-x: auto;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		border-radius: var(--radius);
		box-shadow: var(--shadow-sm);
	}
	.cart-page :global(.cart-table) {
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
		font-size: 0.9375rem;
	}
	.cart-page :global(.cart-table__col--image) {
		width: 5rem;
	}
	.cart-page :global(.cart-table__col--price) {
		width: 5.5rem;
	}
	.cart-page :global(.cart-table__col--qty) {
		width: 7rem;
	}
	.cart-page :global(.cart-table__col--total) {
		width: 5.5rem;
	}
	.cart-page :global(.cart-table__col--remove) {
		width: 3rem;
	}
	.cart-page :global(.cart-table__head) {
		padding: 0.625rem 1rem;
		text-align: left;
		font-family: var(--font-sans);
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-muted);
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border);
		vertical-align: middle;
	}
	.cart-page :global(.cart-table__head--price),
	.cart-page :global(.cart-table__head--total) {
		text-align: right;
		padding-right: 1.25rem;
	}
	.cart-page :global(.cart-table__head--qty),
	.cart-page :global(.cart-table__head--remove) {
		text-align: center;
	}
	.cart-page :global(.cart-table__head--image) {
		padding-left: 1.25rem;
	}
	.cart-page :global(.cart-table__row:not(:last-child) .cart-table__cell) {
		border-bottom: 1px solid var(--color-border);
	}
	.cart-page :global(.cart-table__cell) {
		padding: 1.125rem 1rem;
		vertical-align: middle;
	}
	.cart-page :global(.cart-table__cell--image) {
		padding-left: 1.25rem;
		width: 5rem;
	}
	.cart-page :global(.cart-table__cell--product) {
		padding-inline: 0.5rem 1rem;
		min-width: 0;
	}
	.cart-page :global(.cart-table__cell--price),
	.cart-page :global(.cart-table__cell--total) {
		padding-inline: 0.5rem 1.25rem;
	}
	.cart-page :global(.cart-table__cell--qty),
	.cart-page :global(.cart-table__cell--remove) {
		padding-inline: 0.5rem;
	}
	.cart-page :global(.cart-table__cell-inner) {
		display: flex;
		align-items: center;
		min-height: 2.75rem;
	}
	.cart-page :global(.cart-table__cell-inner--end) {
		justify-content: flex-end;
	}
	.cart-page :global(.cart-table__cell-inner--center) {
		justify-content: center;
	}
	.cart-page :global(.cart-table__money) {
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
		color: var(--color-ink);
	}
	.cart-page :global(.cart-table__money--total) {
		font-weight: 600;
	}
	.cart-page :global(.cart-table__image-link) {
		display: block;
		line-height: 0;
	}
	.cart-page :global(.cart-table__image-link img) {
		display: block;
		width: 4rem;
		height: 5rem;
		object-fit: cover;
		background: #f0eeeb;
		border-radius: var(--radius);
	}
	.cart-page :global(.cart-table__name) {
		display: block;
		font-family: var(--font-display);
		font-size: 1.125rem;
		font-weight: 500;
		line-height: 1.35;
		color: var(--color-ink);
		text-decoration: none;
	}
	.cart-page :global(.cart-table__name:hover) {
		text-decoration: underline;
	}
	.cart-page :global(.cart-table__meta) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 1.25rem;
		margin: 0.4rem 0 0;
		padding: 0;
	}
	.cart-page :global(.cart-table__meta-item) {
		display: inline-flex;
		align-items: baseline;
		gap: 0.35rem;
		font-size: 0.8125rem;
		line-height: 1.4;
	}
	.cart-page :global(.cart-table__meta-label) {
		font-weight: 500;
		color: var(--color-muted);
	}
	.cart-page :global(.cart-table__meta-label::after) {
		content: ':';
	}
	.cart-page :global(.cart-table__meta-value) {
		color: var(--color-ink);
	}
	.cart-page :global(.cart-qty) {
		display: inline-flex;
		align-items: stretch;
		height: 2.25rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-surface);
		overflow: hidden;
	}
	.cart-page :global(.cart-qty__btn) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.125rem;
		height: 100%;
		margin: 0;
		padding: 0;
		border: none;
		background: var(--color-bg);
		color: var(--color-ink);
		cursor: pointer;
		appearance: none;
		-webkit-appearance: none;
		transition: background var(--transition), color var(--transition);
	}
	.cart-page :global(.cart-qty__btn:hover) {
		background: var(--color-border);
	}
	.cart-page :global(.cart-qty__btn:active) {
		background: var(--color-ink);
		color: var(--color-surface);
	}
	.cart-page :global(.cart-qty__btn:focus-visible) {
		outline: 2px solid var(--color-ink);
		outline-offset: -2px;
		z-index: 1;
	}
	.cart-page :global(.cart-qty input) {
		width: 2.5rem;
		height: 100%;
		margin: 0;
		padding: 0;
		border: none;
		border-inline: 1px solid var(--color-border);
		text-align: center;
		font: inherit;
		font-size: 0.875rem;
		font-variant-numeric: tabular-nums;
		font-weight: 600;
		color: var(--color-ink);
		background: var(--color-surface);
		-moz-appearance: textfield;
		cursor: default;
	}
	.cart-page :global(.cart-qty input::-webkit-outer-spin-button),
	.cart-page :global(.cart-qty input::-webkit-inner-spin-button) {
		-webkit-appearance: none;
		margin: 0;
	}
	.cart-page :global(.cart-table__remove) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		margin: 0;
		padding: 0;
		border: 1px solid transparent;
		border-radius: var(--radius);
		background: transparent;
		color: var(--color-muted);
		cursor: pointer;
		appearance: none;
		-webkit-appearance: none;
		transition:
			color var(--transition),
			background var(--transition),
			border-color var(--transition);
	}
	.cart-page :global(.cart-table__remove:hover) {
		color: var(--color-sale);
		background: rgb(179 58 58 / 6%);
		border-color: rgb(179 58 58 / 20%);
	}
	.cart-page :global(.cart-table__remove:focus-visible) {
		outline: 2px solid var(--color-ink);
		outline-offset: 2px;
	}

	@media (max-width: 768px) {
		.cart-page__layout {
			grid-template-columns: 1fr;
		}
		.cart-page :global(.cart-table__col--price),
		.cart-page :global(.cart-table__col--total) {
			width: 4.25rem;
		}
		.cart-page :global(.cart-table__col--qty) {
			width: 6.25rem;
		}
		.cart-page :global(.cart-table__cell) {
			padding: 0.875rem 0.5rem;
		}
		.cart-page :global(.cart-table__image-link img) {
			width: 3.25rem;
			height: 4.0625rem;
		}
		.cart-page :global(.cart-table__name) {
			font-size: 1rem;
		}
		.cart-page :global(.cart-qty) {
			height: 2rem;
		}
		.cart-page :global(.cart-qty__btn) {
			width: 1.875rem;
		}
		.cart-page :global(.cart-qty input) {
			width: 2rem;
			font-size: 0.8125rem;
		}
	}
</style>
