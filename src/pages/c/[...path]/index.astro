---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ProductCard from '../../../components/ProductCard.astro';
import FilterSidebar from '../../../components/FilterSidebar.astro';
import { getDatabase, hasDatabase } from '../../../lib/db/bindings';
import {
	categoryHref,
	categorySlugFromPath,
	collectDescendantSlugs,
	findParentCategory,
	getCategoryBySlug,
	getDefaultCatalogHref,
	listCategories,
	listChildCategories,
	resolveCatalogId,
} from '../../../lib/db/categories';
import {
	listLocalizedProducts,
	parseProductFiltersFromUrl,
	parseProductSort,
} from '../../../lib/db/products';
import { loadSiteNavigation } from '../../../lib/site/navigation';
import { useTranslations } from '../../../i18n';

const t = useTranslations(Astro.currentLocale);
const slug = categorySlugFromPath(Astro.params.path);

if (!slug) {
	const nav = await loadSiteNavigation();
	return Astro.redirect(nav.defaultCatalogHref);
}

if (!hasDatabase()) {
	return Astro.redirect('/');
}

const db = getDatabase();
const catalogId = await resolveCatalogId(db);
const category = await getCategoryBySlug(db, slug, catalogId);

if (!category) {
	return Astro.redirect(await getDefaultCatalogHref(db, catalogId));
}

const allCategories = await listCategories(db, catalogId);
const categorySlugs = collectDescendantSlugs(allCategories, slug);
const childCategories = listChildCategories(allCategories, slug);
const urlFilters = parseProductFiltersFromUrl(Astro.url);
const sort = parseProductSort(Astro.url);

const localized = await listLocalizedProducts(
	db,
	Astro.currentLocale,
	{ ...urlFilters, categorySlugs },
	sort,
);

const productData = localized.map((p) => ({
	slug: p.slug,
	name: p.name,
	price: p.price,
	originalPrice: p.originalPrice ?? null,
	badge: p.badge ?? null,
}));

const sortKeys = ['popular', 'price-asc', 'price-desc', 'new'] as const;
const breadcrumbItems = [{ label: t.brand, href: '/' }];

const parent = findParentCategory(allCategories, category);
if (parent) {
	breadcrumbItems.push({ label: parent.name, href: categoryHref(parent.slug) });
}

breadcrumbItems.push({ label: category.name });
---

<BaseLayout title={category.name} description={t.catalog.metaDescription}>
	<div class="container listing">
		<Breadcrumbs items={breadcrumbItems} />

		<header class="listing__header">
			<div>
				<h1>{category.name}</h1>
				<p class="listing__count">
					<span data-result-count>{localized.length}</span> {t.catalog.productCount}
				</p>
			</div>
			<div class="listing__toolbar">
				<button type="button" class="listing__filter-btn" data-open-filters>{t.catalog.filters}</button>
				<label class="listing__sort">
					<span class="sr-only">{t.catalog.sortLabel}</span>
					<select name="sort" data-sort>
						{sortKeys.map((key) => (
							<option value={key} selected={sort === key}>{t.catalog.sort[key]}</option>
						))}
					</select>
				</label>
			</div>
		</header>

		{childCategories.length > 0 && (
			<nav class="listing__subcats" aria-label={t.aria.mainNav}>
				<ul>
					{childCategories.map((child) => (
						<li>
							<a href={categoryHref(child.slug)} class:list={{ 'is-active': child.slug === slug }}>
								{child.name}
							</a>
						</li>
					))}
				</ul>
			</nav>
		)}

		<div class="listing__layout">
			<FilterSidebar />
			<div class="listing__main">
				<div class="active-filters" data-active-filters hidden></div>
				<div class="product-grid" data-product-grid>
					{localized.map((product) => (
						<ProductCard product={product} />
					))}
				</div>
				<p class="listing__empty" data-empty hidden>{t.catalog.empty}</p>
			</div>
		</div>
	</div>
</BaseLayout>

<script define:vars={{ productData, priceUpToTemplate: 'Até {max} €', priceMax: 800 }}>
	const grid = document.querySelector('[data-product-grid]');
	const cards = [...document.querySelectorAll('[data-product-card]')];
	const countEl = document.querySelector('[data-result-count]');
	const emptyEl = document.querySelector('[data-empty]');
	const sortSelect = document.querySelector('[data-sort]');
	const priceRange = document.querySelector('[data-filter="price"]');
	const priceDisplay = document.querySelector('[data-price-display]');

	const params = new URLSearchParams(window.location.search);

	function formatPriceUpTo(max) {
		return priceUpToTemplate.replace('{max}', String(max));
	}

	function getActiveFilters() {
		const filters = { sale: false, q: '' };
		if (params.get('sale') === 'true') filters.sale = true;
		filters.q = (params.get('q') || '').toLowerCase();
		return filters;
	}

	function applyUrlToFilters() {
		const sort = params.get('sort');
		if (sort && sortSelect) sortSelect.value = sort;
		const q = params.get('q');
		if (q) {
			const searchInput = document.getElementById('header-search');
			if (searchInput) searchInput.value = q;
		}
	}

	function matchesFilters(slug, filters, maxPrice) {
		const p = productData.find((x) => x.slug === slug);
		if (!p) return false;
		if (filters.sale && !p.originalPrice) return false;
		if (filters.q && !p.name.toLowerCase().includes(filters.q)) return false;
		if (p.price > maxPrice) return false;
		const badge = params.get('badge');
		if (badge && p.badge !== badge) return false;
		return true;
	}

	function sortCards(visible, sortBy) {
		const order = visible.map((card) => card.dataset.slug);
		const sorted = [...productData]
			.filter((p) => order.includes(p.slug))
			.sort((a, b) => {
				switch (sortBy) {
					case 'price-asc':
						return a.price - b.price;
					case 'price-desc':
						return b.price - a.price;
					case 'new':
						return (b.badge === 'new' ? 1 : 0) - (a.badge === 'new' ? 1 : 0);
					default:
						return (b.badge === 'bestseller' ? 1 : 0) - (a.badge === 'bestseller' ? 1 : 0);
				}
			});
		sorted.forEach((p) => {
			const card = cards.find((c) => c.dataset.slug === p.slug);
			if (card) grid?.appendChild(card);
		});
	}

	function updateListing() {
		const filters = getActiveFilters();
		const maxPrice = priceRange ? Number(priceRange.value) : priceMax;
		const sortBy = sortSelect?.value || 'popular';
		let visible = 0;

		cards.forEach((card) => {
			const show = matchesFilters(card.dataset.slug, filters, maxPrice);
			card.style.display = show ? '' : 'none';
			if (show) visible++;
		});

		sortCards(cards.filter((c) => c.style.display !== 'none'), sortBy);

		if (countEl) countEl.textContent = String(visible);
		if (emptyEl) emptyEl.hidden = visible > 0;
	}

	applyUrlToFilters();
	updateListing();

	document.querySelectorAll('[data-filter]').forEach((el) => {
		el.addEventListener('change', updateListing);
	});
	priceRange?.addEventListener('input', () => {
		if (priceDisplay) priceDisplay.textContent = formatPriceUpTo(priceRange.value);
		updateListing();
	});
	sortSelect?.addEventListener('change', updateListing);

	document.querySelector('[data-clear-filters]')?.addEventListener('click', () => {
		document.querySelectorAll('[data-filter]').forEach((el) => {
			if (el.type === 'checkbox') el.checked = false;
			if (el.type === 'range') el.value = String(priceMax);
		});
		if (priceDisplay) priceDisplay.textContent = formatPriceUpTo(priceMax);
		updateListing();
	});

	document.querySelector('[data-open-filters]')?.addEventListener('click', () => {
		document.getElementById('filters')?.classList.toggle('filters--open');
	});
</script>

<style>
	.listing {
		padding: 1.5rem 0 4rem;
	}
	.listing__header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1.5rem;
		margin: 1.5rem 0 2rem;
	}
	.listing h1 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 2.5rem;
		font-weight: 500;
	}
	.listing__count {
		margin: 0.35rem 0 0;
		color: var(--color-muted);
		font-size: 0.875rem;
	}
	.listing__subcats {
		margin-bottom: 1.5rem;
	}
	.listing__subcats ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.listing__subcats a {
		display: inline-block;
		padding: 0.45rem 0.85rem;
		border: 1px solid var(--color-border);
		font-size: 0.8125rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.listing__subcats a.is-active {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}
	.listing__toolbar {
		display: flex;
		gap: 1rem;
		align-items: center;
	}
	.listing__filter-btn {
		display: none;
		padding: 0.6rem 1rem;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		cursor: pointer;
		font-size: 0.8125rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	.listing__sort select {
		padding: 0.6rem 2rem 0.6rem 0.75rem;
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		cursor: pointer;
		font-size: 0.875rem;
	}
	.listing__layout {
		display: grid;
		grid-template-columns: 240px 1fr;
		gap: 2.5rem;
		align-items: start;
	}
	.listing__main .product-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.listing__empty {
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem;
		color: var(--color-muted);
	}
	@media (max-width: 1024px) {
		.listing__layout {
			grid-template-columns: 1fr;
		}
		.listing #filters {
			display: none;
			position: fixed;
			inset: 0;
			z-index: 200;
			padding: 1.5rem;
			background: var(--color-surface);
			overflow-y: auto;
		}
		.listing #filters.filters--open {
			display: block;
		}
		.listing__filter-btn {
			display: block;
		}
		.listing__main .product-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (max-width: 480px) {
		.listing__main .product-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
