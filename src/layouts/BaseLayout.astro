---
import '../styles/fonts.css';
import '../styles/global.css';
import dmSans400 from '@fontsource/dm-sans/files/dm-sans-latin-ext-400-normal.woff2?url';
import cormorant400 from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-ext-400-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustBar from '../components/TrustBar.astro';
import { useTranslations } from '../i18n';
import { resolveRequestLocale } from '../lib/i18n/resolve-request-locale';
import { appearanceStyleTag, loadSiteAppearance } from '../lib/site/appearance';

interface Props {
	title: string;
	description?: string;
}

const requestLocale = resolveRequestLocale(Astro.url, Astro.currentLocale);
const t = useTranslations(requestLocale);
const editMode = Astro.url.searchParams.has('edit');
const { title, description = t.meta.defaultDescription } = Astro.props;
const fullTitle = title === t.brand ? title : `${title} | ${t.meta.titleSuffix}`;
const lang = requestLocale;
const appearance = await loadSiteAppearance();
const themeVars = appearanceStyleTag(appearance);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://womni.fra1.cdn.digitaloceanspaces.com" crossorigin />
		<link rel="preload" href={dmSans400} as="font" type="font/woff2" crossorigin />
		<link rel="preload" href={cormorant400} as="font" type="font/woff2" crossorigin />
		<title>{fullTitle}</title>
		<style is:global set:html={themeVars} />
	</head>
	<body>
		<TrustBar editMode={editMode} locale={requestLocale} />
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
