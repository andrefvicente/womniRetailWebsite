---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustBar from '../components/TrustBar.astro';
import { useTranslations } from '../i18n';

interface Props {
	title: string;
	description?: string;
}

const t = useTranslations(Astro.currentLocale);
const { title, description = t.meta.defaultDescription } = Astro.props;
const fullTitle = title === t.brand ? title : `${title} | ${t.meta.titleSuffix}`;
const lang = Astro.currentLocale ?? 'pt';
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
	</head>
	<body>
		<TrustBar />
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
