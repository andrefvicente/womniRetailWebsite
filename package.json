{
  "name": "womni-rugs",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "db:create": "wrangler d1 create womni-rugs-db",
    "db:generate-seed": "tsx scripts/generate-seed.mjs",
    "db:migrate:local": "wrangler d1 migrations apply womni-rugs-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply womni-rugs-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.3",
    "astro": "^6.3.6",
    "wrangler": "^4.93.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260521.1",
    "tsx": "^4.22.3"
  }
}
